:messageWidget  a skosmos:ParameterizedPlugin;
                skosmos:usePlugin "message";
                skosmos:parameters [
                  a schema:PropertyValue;
                  schema:propertyID "msg";
                  schema:value "Ce vocabulaire n'est plus mis à jour."@fr , "This vocabulary is no longer updated."@en, "Este vocabulario ya no se actualiza."@es;
                ],
                [
                        a schema:PropertyValue ;
                        schema:propertyID "color" ;
                        schema:value "#800000" ;
                    ] ,
                    [
                        a schema:PropertyValue ;
                        schema:propertyID "imageUrl" ;
                        schema:value "https://fr.wikipedia.org/wiki/Wikip%C3%A9dia:Accueil_principal#/media/Fichier:Orlaya_grandiflora_Sturm34.jpg" ;
                    ] .

:messageWidget2  a skosmos:ParameterizedPlugin;
                skosmos:usePlugin "message";
                skosmos:parameters [
                  a schema:PropertyValue;
                  schema:propertyID "msg";
                  schema:value "Cette terminologie est une preuve de concept de la construction d’une ressource à partir d’un corpus thématique d’actualité, à l'aide d'un outil d'extraction terminologique.
Elle ne peut être considérée comme une représentation exhaustive du domaine scientifique, mais peut être une source d’inspiration ou de données pour des travaux plus approfondis."@fr, "This terminology is a proof of concept of the construction of a resource from a topical corpus, using a terminology extraction tool. It cannot be considered an exhaustive representation of the scientific domain, but can be a source of inspiration or data for further work."@en, "Esta terminología es una prueba de concepto de la construcción de un recurso a partir de un corpus temático, utilizando una herramienta de extracción terminológica.
No puede considerarse una representación exhaustiva del ámbito científico, pero puede ser una fuente de inspiración o datos para trabajos posteriores."@es;
                ],
                [
                        a schema:PropertyValue ;
                        schema:propertyID "color" ;
                        schema:value "#800000" ;
                    ] ,
                    [
                        a schema:PropertyValue ;
                        schema:propertyID "imageUrl" ;
                        schema:value "https://fr.wikipedia.org/wiki/Climat#/media/Fichier:Map_world_climate_zones_(simplified_to_10)-fr.svg" ;
                    ] .
					
					
:messageWidget3  a skosmos:ParameterizedPlugin;
                skosmos:usePlugin "message";
                skosmos:parameters [
                  a schema:PropertyValue;
                  schema:propertyID "msg";
                  schema:value "Cette ressource est une preuve de concept de l’utilisation des standards du web des données ouvertes et liées (LOD) ainsi que des principes FAIR pour l’exposition des sections du CoNRS.
Elle ne se substitue pas aux travaux du CoNRS."@fr , "This resource is a proof of concept of the use of Open and Linked Data (OLD) web standards and FAIR principles for the exposure of CoNRS sections. It does not replace the work of the CoNRS."@en, "Este recurso es una prueba de concepto del uso de los estándares web Open and Linked Data (OLD) y de los principios FAIR para la exposición de las secciones de CoNRS. No sustituye el trabajo de CoNRS."@es;
                ],
                [
                        a schema:PropertyValue ;
                        schema:propertyID "color" ;
                        schema:value "#800000" ;
                    ] ,
                    [
                        a schema:PropertyValue ;
                        schema:propertyID "imageUrl" ;
                        schema:value "https://fr.wikipedia.org/wiki/Climat#/media/Fichier:Map_world_climate_zones_(simplified_to_10)-fr.svg" ;
                    ] .

